{
  "info": {
    "name": "ESG EcoAl API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "token", "value": "" },
    { "key": "companyId", "value": "" },
    { "key": "goalId", "value": "" },
    { "key": "taskId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": { "type": "text/javascript", "exec": [""] }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Sign Up",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('companyId', body.company_id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/sign-up",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice\",\n  \"email\": \"alice@example.com\",\n  \"password\": \"secret123\",\n  \"role\": \"admin\",\n  \"cnpj\": \"12345678000100\"\n}"
            }
          }
        },
        {
          "name": "Sign In",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('token', body.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{baseUrl}}/api/auth/sign-in",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"secret123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Companies",
      "item": [
        {
          "name": "Create Company",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('companyId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/companies",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"EcoAl Corp\",\n  \"cnpj\": \"12345678000100\",\n  \"global_score_goal\": 100\n}"
            }
          }
        },
        {
          "name": "Get Company",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/companies/{{companyId}}"
          }
        },
        {
          "name": "Update Company",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/companies/{{companyId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"EcoAl Corp Updated\",\n  \"cnpj\": \"12345678000100\",\n  \"global_score_goal\": 200\n}"
            }
          }
        },
        {
          "name": "Delete Company",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/companies/{{companyId}}"
          }
        }
      ]
    },
    {
      "name": "Goals",
      "item": [
        {
          "name": "Create Goal",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('goalId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/goals",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Reduce carbon emissions\",\n  \"description\": \"Cut emissions by 30% by 2027\",\n  \"dimension\": \"environmental\"\n}"
            }
          }
        },
        {
          "name": "List Goals",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/goals?dimension=environmental",
              "host": ["{{baseUrl}}"],
              "path": ["api", "goals"],
              "query": [
                { "key": "dimension", "value": "environmental", "disabled": true },
                { "key": "created_at", "value": "2026-01-01", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Goal",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/goals/{{goalId}}"
          }
        },
        {
          "name": "Update Goal",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/goals/{{goalId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Reduce carbon emissions\",\n  \"description\": \"Updated description\",\n  \"dimension\": \"environmental\"\n}"
            }
          }
        },
        {
          "name": "Delete Goal",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/goals/{{goalId}}"
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "Create Task",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('taskId', body.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/goals/{{goalId}}/tasks",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Install solar panels\",\n  \"description\": \"Office building rooftop\",\n  \"score\": 25\n}"
            }
          }
        },
        {
          "name": "List Tasks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/goals/{{goalId}}/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "goals", "{{goalId}}", "tasks"],
              "query": [
                { "key": "completed", "value": "true", "disabled": true },
                { "key": "completed_at", "value": "true", "disabled": true },
                { "key": "created_at", "value": "2026-01-01", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Task",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/goals/{{goalId}}/tasks/{{taskId}}"
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/api/goals/{{goalId}}/tasks/{{taskId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Install solar panels\",\n  \"description\": \"Completed installation\",\n  \"score\": 25,\n  \"completed\": true,\n  \"completed_at\": \"2026-03-11T00:00:00Z\"\n}"
            }
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/goals/{{goalId}}/tasks/{{taskId}}"
          }
        }
      ]
    },
    {
      "name": "Analytics",
      "item": [
        {
          "name": "Dimensions",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/analytics/dimensions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "analytics", "dimensions"],
              "query": [
                { "key": "period", "value": "monthly", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Score",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/analytics/score"
          }
        }
      ]
    }
  ]
}
